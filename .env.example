# Notion integration token (starts with ntn_)
NOTION_TOKEN=ntn_your_token_here

# Notion database IDs (32-character hex from the database URL)
NOTION_GLOBAL_DB=your_global_tokens_database_id
NOTION_SEMANTIC_DB=your_semantic_tokens_database_id
NOTION_COMPONENT_DB=your_component_tokens_database_id

# Path to flintwork's token directory
FLINTWORK_TOKENS_PATH=../flintwork/src/tokens
